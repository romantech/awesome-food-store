{
  "name": "awesome-food-store",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "biome lint .",
    "db": "json-server --watch db.json --port 3001",
    "format": "biome format --write .",
    "lint-fix": "biome lint --write .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": ["biome check --write"]
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "classnames": "^2.5.1",
    "next": "16.1.6",
    "next-plugin-antd-less": "^1.8.0",
    "next-use-contextual-routing": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "@biomejs/biome": "^2.4.6",
    "antd": "4.24.14",
    "autoprefixer": "^10.4.27",
    "babel-plugin-import": "^1.13.8",
    "husky": "^8.0.3",
    "json-server": "^0.17.4",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}
